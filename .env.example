# ─── Banco de Dados ──────────────────────────────────────────────────────────
POSTGRES_USER=sgm
POSTGRES_PASSWORD=sgm_secret_change_me
POSTGRES_DB=sgm_ferroviario

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret_change_me

# ─── RabbitMQ ────────────────────────────────────────────────────────────────
RABBITMQ_USER=sgm
RABBITMQ_PASSWORD=sgm_secret_change_me

# ─── EMQX (MQTT IoT) ─────────────────────────────────────────────────────────
EMQX_PASSWORD=emqx_secret_change_me

# ─── Segurança ───────────────────────────────────────────────────────────────
SECRET_KEY=gere_uma_chave_aleatoria_segura_aqui_256bits
ENVIRONMENT=production

# ─── SCADA ───────────────────────────────────────────────────────────────────
OPCUA_SERVER_URL=opc.tcp://scada-server:4840/
MODBUS_HOST=192.168.1.100
MODBUS_PORT=502

# ─── ERP ─────────────────────────────────────────────────────────────────────
ERP_TYPE=sap                          # sap | totvs | oracle | generic
SAP_BASE_URL=https://sap.empresa.com.br/api
SAP_CLIENT_ID=your_client_id
SAP_CLIENT_SECRET=your_client_secret
TOTVS_BASE_URL=https://totvs.empresa.com.br/api/framework/v1
TOTVS_USERNAME=your_username
TOTVS_PASSWORD=your_password

# ─── Notificações ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.empresa.com.br
SMTP_PORT=587
SMTP_USER=noreply@empresa.com.br
SMTP_PASSWORD=email_password
PUSHOVER_TOKEN=your_pushover_token
